[Unit]
Description=Blueprints App (xarta-node)
After=network.target tailscaled.service
Wants=tailscaled.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/xarta-node/blueprints-app
EnvironmentFile=/opt/blueprints/.env
ExecStart=/opt/blueprints/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
