#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT"

ACTION_HINTS_SCRIPT="/root/xarta-node/.xarta/.claude/skills/docs-operations/scripts/pre-commit-action-hints.sh"
if [[ -f "$ACTION_HINTS_SCRIPT" ]]; then
  # shellcheck source=/dev/null
  source "$ACTION_HINTS_SCRIPT"
fi

print_root_script_hints() {
  local reason="$1"
  local script="$2"
  local bash_path
  bash_path="$(command -v bash 2>/dev/null || printf 'bash')"
  if declare -F xarta_precommit_print_common_context >/dev/null 2>&1; then
    xarta_precommit_print_common_context "$reason"
    echo "  tool paths:" >&2
    xarta_precommit_print_tool_paths
    xarta_precommit_print_path_status "script" "$script"
    echo "  rerun command:" >&2
    xarta_precommit_print_command "$bash_path" "$script"
  fi
}

is_env_backup_name() {
  local name="$1"
  case "$name" in
    .env.bak|.env.bak-*|.env.bak.*|.env.backup|.env.backup-*|.env.backup.*|.env.*.bak|.env.*.bak-*|.env.*.bak.*|.env.*.backup|.env.*.backup-*|.env.*.backup.*)
      return 0
      ;;
  esac
  return 1
}

collect_env_backup_hits() {
  local mode="$1"
  local path
  if [[ "$mode" == "tracked" ]]; then
    git ls-files
  else
    git diff --cached --name-only --diff-filter=ACMR
  fi | while IFS= read -r path; do
    local bn
    bn="$(basename "$path")"
    if is_env_backup_name "$bn"; then
      echo "$path"
    fi
  done
}

mapfile -t TRACKED_HITS < <(collect_env_backup_hits tracked)
mapfile -t STAGED_HITS < <(collect_env_backup_hits staged)

if [[ ${#TRACKED_HITS[@]} -gt 0 || ${#STAGED_HITS[@]} -gt 0 ]]; then
  echo "[pre-commit] BLOCKED: .env backup artifacts detected in git state." >&2
  if [[ ${#TRACKED_HITS[@]} -gt 0 ]]; then
    echo "Tracked:" >&2
    printf '  %s\n' "${TRACKED_HITS[@]}" >&2
  fi
  if [[ ${#STAGED_HITS[@]} -gt 0 ]]; then
    echo "Staged:" >&2
    printf '  %s\n' "${STAGED_HITS[@]}" >&2
  fi
  echo "Remove these files from git and keep them ignored." >&2
  exit 1
fi

echo "[pre-commit] Running public leak check..."
if ! bash "$REPO_ROOT/check-for-leaks.sh"; then
  echo "[pre-commit] BLOCKED: public leak check failed." >&2
  print_root_script_hints "public leak check failed" "$REPO_ROOT/check-for-leaks.sh"
  exit 1
fi

if [[ -x "$REPO_ROOT/check-caddy-route-parity.sh" ]]; then
  echo "[pre-commit] Running Caddy route parity check..."
  if ! bash "$REPO_ROOT/check-caddy-route-parity.sh"; then
    echo "[pre-commit] BLOCKED: Caddy route parity check failed." >&2
    if declare -F xarta_precommit_print_caddy_hints >/dev/null 2>&1; then
      xarta_precommit_print_caddy_hints "Caddy route parity failed"
    else
      print_root_script_hints "Caddy route parity failed" "$REPO_ROOT/check-caddy-route-parity.sh"
    fi
    exit 1
  fi
fi

run_active_browser_live_checks() {
  local runner="/root/xarta-node/.xarta/.claude/skills/xarta-blueprints-browser-automation/scripts/active_browser_precommit_test.py"
  local staged_pattern='^(blueprints-app/app/routes_voice_mode\.py|blueprints-app/app/routes_events\.py|tests/test_voice_mode\.py|setup-caddy\.sh|setup-blueprints.*|\.githooks/pre-commit)$'

  if [[ "${XARTA_PRECOMMIT_ACTIVE_BROWSER:-0}" != "1" ]]; then
    echo "[pre-commit] Active Browser live checks disabled (set XARTA_PRECOMMIT_ACTIVE_BROWSER=1 to enable)."
    return 0
  fi

  if ! git diff --cached --name-only --diff-filter=ACMR | grep -Eq "$staged_pattern"; then
    echo "[pre-commit] No staged Active Browser API/test files; skipping live browser checks."
    return 0
  fi

  if [[ ! -x "$runner" ]]; then
    echo "[pre-commit] BLOCKED: Active Browser pre-commit runner not found at $runner" >&2
    print_root_script_hints "Active Browser runner missing" "$runner"
    exit 1
  fi

  echo "[pre-commit] Running Active Browser live automation checks..."
  if ! python3 "$runner"; then
    echo "[pre-commit] BLOCKED: Active Browser live automation checks failed." >&2
    if declare -F xarta_precommit_print_common_context >/dev/null 2>&1; then
      python_path="$(command -v python3 2>/dev/null || printf 'python3')"
      xarta_precommit_print_common_context "Active Browser live automation checks failed"
      echo "  tool paths:" >&2
      xarta_precommit_print_tool_paths
      xarta_precommit_print_path_status "Active Browser pre-commit runner" "$runner"
      echo "  rerun command:" >&2
      xarta_precommit_print_command "$python_path" "$runner"
    fi
    exit 1
  fi
}

run_active_browser_live_checks

# ── Ruff: lint staged Python files ───────────────────────────────────────────
mapfile -t STAGED_PY < <(git diff --cached --name-only --diff-filter=ACMR | grep '\.py$' || true)

if [[ ${#STAGED_PY[@]} -gt 0 ]]; then
  if ! command -v ruff >/dev/null 2>&1; then
    echo "[pre-commit] BLOCKED: ruff not found. Run: bash setup-python-dev-tools.sh" >&2
    if declare -F xarta_precommit_print_ruff_hints >/dev/null 2>&1; then
      xarta_precommit_print_ruff_hints "ruff not found" "${STAGED_PY[@]}"
    fi
    exit 1
  fi

  echo "[pre-commit] Running ruff check on ${#STAGED_PY[@]} staged Python file(s)..."
  ruff check "${STAGED_PY[@]}" || {
    echo "[pre-commit] BLOCKED: ruff found lint errors. Fix them or use 'git commit --no-verify' to skip." >&2
    if declare -F xarta_precommit_print_ruff_hints >/dev/null 2>&1; then
      xarta_precommit_print_ruff_hints "ruff check failed" "${STAGED_PY[@]}"
    fi
    exit 1
  }

  echo "[pre-commit] Running ruff format check on ${#STAGED_PY[@]} staged Python file(s)..."
  ruff format --check "${STAGED_PY[@]}" || {
    echo "[pre-commit] BLOCKED: ruff found formatting drift. Fix it or use 'git commit --no-verify' to skip." >&2
    if declare -F xarta_precommit_print_ruff_hints >/dev/null 2>&1; then
      xarta_precommit_print_ruff_hints "ruff format check failed" "${STAGED_PY[@]}"
    fi
    exit 1
  }
fi

echo "[pre-commit] OK"
