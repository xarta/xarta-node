# Secrets and local deploy config — never commit these
.env
.env.bak*
.env.backup*
.env.*.bak*
.env.*.backup*
.nodes.json
.xarta/
.lone-wolf/
fleet-hosts.conf

# gui/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# Build artefacts
*.tar.gz
*.zip

# SQLite databases (runtime data, never source)
*.db
*.db-shm
*.db-wal

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
.certs/

# Nav item assets — gitignored (may contain proprietary icons/sounds)
# fallback.svg is NOT ignored — it ships with the repo as the default icon
gui-fallback/assets/icons/*
!gui-fallback/assets/icons/fallback.svg
gui-fallback/assets/sounds/*

# Roo skill index — generated, never commit
.roo/skills/skill-discovery/references/SKILL-INDEX.md
