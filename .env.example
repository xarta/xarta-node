# -----------------------------------------------------------------------------
# Gateway Failover Configuration — Template
# Copy this file to .env and fill in your site-specific values.
# .env is gitignored and must NOT be committed.
# -----------------------------------------------------------------------------

# Network interfaces inside the LXC
# (Proxmox vNIC device names as seen inside the container, e.g. net3, net4, eth1)
IF_PRIMARY="net4"
IF_SECONDARY="net3"

# Gateway IPs for each interface
GW_PRIMARY="192.168.X.1"
GW_SECONDARY="192.168.Y.1"

# IP address used to test connectivity (e.g. a reliable public DNS server)
TEST_IP="1.1.1.1"
