# -----------------------------------------------------------------------------
# Configuration — Template
# Copy this file to .env and fill in your site-specific values.
# .env is gitignored and must NOT be committed.
# -----------------------------------------------------------------------------

# Network interfaces inside the LXC
# (vNIC device names as seen inside the container, e.g. eth0, eth1, net0)
IF_PRIMARY="<primary-interface>"
IF_SECONDARY="<secondary-interface>"

# Gateway IPs for each interface
GW_PRIMARY="<primary-gateway-ip>"
GW_SECONDARY="<secondary-gateway-ip>"

# IP address used to test connectivity
TEST_IP="<test-ip>"

# -----------------------------------------------------------------------------
# Auto-update configuration
# -----------------------------------------------------------------------------

# Absolute path where the primary repo is checked out on this host
REPO_OUTER_PATH="<path-to-primary-repo>"

# Absolute path where the secondary repo is checked out on this host
# Leave blank to skip
REPO_INNER_PATH="<path-to-secondary-repo>"

# Seconds before a git pull is abandoned (keeps cron non-blocking)
GIT_TIMEOUT=5

# Log file for the auto-update script
AUTO_UPDATE_LOG="/var/log/auto-update.log"
