# -----------------------------------------------------------------------------
# Configuration — Template
# Copy this file to .env and fill in your site-specific values.
# .env is gitignored and must NOT be committed.
# -----------------------------------------------------------------------------

# Network interfaces inside the LXC
# (vNIC device names as seen inside the container, e.g. eth0, eth1, net0)
IF_PRIMARY="<primary-interface>"
IF_SECONDARY="<secondary-interface>"

# Gateway IPs for each interface
GW_PRIMARY="<primary-gateway-ip>"
GW_SECONDARY="<secondary-gateway-ip>"

# IP address used to test connectivity
TEST_IP="<test-ip>"


# -----------------------------------------------------------------------------
# Auto-update configuration
# -----------------------------------------------------------------------------

# Absolute path where the outer (public) repo is checked out on this host
REPO_OUTER_PATH="<path-to-outer-repo>"

# Absolute path where the inner (private) repo is checked out on this host
# Leave blank to skip
REPO_INNER_PATH="<path-to-inner-repo>"

# Absolute path of the node-local config repo — holds the Caddyfile for this host.
# Each node keeps its own independent git repo here because the Caddyfile content
# (hostnames, cert paths) differs per node and must not be shared across the fleet.
# Required by setup-caddy.sh — repo must exist before running that script.
REPO_CADDY_PATH="<path-to-node-local-config-repo>"

# Seconds before a git pull is abandoned (keeps the boot service non-blocking)
GIT_TIMEOUT=5

# Log file for the auto-update script
AUTO_UPDATE_LOG="/var/log/auto-update.log"

# Command to restart the app service after a git pull (bare-systemd nodes)
SERVICE_RESTART_CMD="systemctl restart <service-name>"


# -----------------------------------------------------------------------------
# SSH / Git Configuration
# -----------------------------------------------------------------------------

# Filename of the SSH key used for git operations (must exist in /root/.ssh/)
SSH_KEY_NAME="<ssh-key-filename>"

# Git global identity for commits and pull authentication on this node
GIT_USER_NAME="<git-username>"
GIT_USER_EMAIL="<git-email>"


# -----------------------------------------------------------------------------
# Blueprints Node Configuration
# -----------------------------------------------------------------------------

# Unique identifier for this node (used in the DB and sync routing)
BLUEPRINTS_NODE_ID=<node-id>

# Human-readable display name
BLUEPRINTS_NODE_NAME=<node-name>

# Instance number (used when multiple instances run on the same host)
BLUEPRINTS_INSTANCE=1

# Hostname of the physical/virtual machine running this node
BLUEPRINTS_HOST_MACHINE=<host-machine>

# Data directories (bare-metal paths)
BLUEPRINTS_DB_DIR=<path-to-data>/db
BLUEPRINTS_GUI_DIR=<path-to-inner-repo>/gui
BLUEPRINTS_BACKUP_DIR=<path-to-inner-repo>/db-backups

# SeekDB server mode (package-manager/systemd local service)
# Keep host as 127.0.0.1; this workspace expects a local package-managed SeekDB service.
SEEKDB_HOST=127.0.0.1
SEEKDB_PORT=2881
SEEKDB_DB=browser_links
SEEKDB_USER=root
SEEKDB_PASSWORD=

# Browser-facing URL for this node (served via Caddy over HTTPS)
BLUEPRINTS_UI_URL=https://<hostname>.<your-domain>

# Allowed CORS origins (comma-separated, no trailing slashes).
# Any origin not in this list (and not a registered peer node) will be blocked
# by the browser from reading API responses. Add every hostname from which
# the embed component may be served — each scheme+host+port is a distinct origin.
# Peer node ui_urls are added automatically from the DB at runtime.
BLUEPRINTS_CORS_ORIGINS=http://<node-1-hostname>:8080,http://<node-2-hostname>:8080

# This node's own address as seen by peers (must be a reachable IP/hostname, not localhost)
BLUEPRINTS_SELF_ADDRESS=http://<tailscale-or-lan-ip>:8080

# Peer node base URLs (comma-separated)
# These nodes will be registered locally and receive a DB backup on first contact
BLUEPRINTS_PEERS=http://<peer-ip>:8080


# -----------------------------------------------------------------------------
# TLS / Certificates
# -----------------------------------------------------------------------------

# Directory where TLS certificates are stored (inside the private inner repo).
# Defaults to <inner-repo>/.certs if not set. Created if it doesn't exist.
CERTS_DIR=<path-to-inner-repo>/.certs

# Active certificate, key, and CA cert — populated automatically by
# setup-certificates.sh. Override here to use a specific cert instead.
CERT_FILE=<path-to-cert.crt>
CERT_KEY=<path-to-cert.key>
CERT_CA=<path-to-ca.crt>


# -----------------------------------------------------------------------------
# Tailscale
# -----------------------------------------------------------------------------

# Hostname advertised to the tailnet
TAILSCALE_HOSTNAME=<node-hostname>

# Comma-separated CIDRs to advertise into the tailnet (one per LXC interface/VLAN)
TAILSCALE_ROUTES=<cidr1>,<cidr2>,<cidr3>

# Advertise this node as a Tailscale exit node (true/false)
TAILSCALE_EXIT_NODE=true

# Accept DNS settings pushed by the control server (usually false for gateway nodes)
TAILSCALE_ACCEPT_DNS=false

# Control server URL — leave blank to use official Tailscale coordination server.
# Set to your Headscale instance URL for self-hosted setups.
TAILSCALE_LOGIN_SERVER=<headscale-url-or-blank>

# Optional pre-auth key for unattended / scripted registration.
# Leave blank to use interactive browser-based login instead.
TAILSCALE_AUTH_KEY=


# -----------------------------------------------------------------------------
# Caddy
# -----------------------------------------------------------------------------

# Additional hostnames Caddy should accept (comma-separated, no scheme or port).
# BLUEPRINTS_UI_URL hostname is always included. Add any other DNS names that
# resolve to this node and should be served over HTTPS.
CADDY_EXTRA_NAMES=<extra-hostname-1>,<extra-hostname-2>